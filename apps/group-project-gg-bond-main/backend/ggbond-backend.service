[Unit]
Description=GG Bond Backend API
After=network.target mysql.service
Requires=mysql.service

[Service]
Type=simple
WorkingDirectory=/home/destiny/backend
ExecStart=/usr/bin/node /home/destiny/backend/src/index.js
Restart=always
RestartSec=3
User=destiny
Environment=NODE_ENV=production
Environment=PORT=5000
StandardOutput=append:/home/destiny/backend/backend.log
StandardError=append:/home/destiny/backend/backend.log

[Install]
WantedBy=multi-user.target
